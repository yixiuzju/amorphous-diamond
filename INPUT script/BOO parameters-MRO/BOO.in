label loop1
units        metal
boundary     s s s
atom_style   atomic
atom_modify    map  yes

variable name index dat1 dat2 dat3 dat4 dat5 dat6 dat7 dat8 dat9 dat10 dat11 dat12 dat13 dat14 dat15 dat16 dat17 dat18 dat19 dat20 dat21 dat22 dat23 dat24 dat25 dat26 dat27 dat28 dat29 dat30 dat31 dat32 dat33 dat34 dat35 dat36 dat37 dat38 dat39 dat40 dat41 dat42 dat43 dat44 dat45 dat46 dat47 dat48 dat49 dat50 dat51 dat52 dat53 dat54 dat55 dat56 dat57 dat58 dat59 dat60 dat61 dat62 dat63 dat64
read_data   ${name}a.data

label loop2
clear
units        metal
boundary     s s s
atom_style   atomic
atom_modify    map  yes
read_data   ${name}a.data
thermo_style custom xlo xhi ylo yhi zlo zhi
region 0 block INF INF INF INF INF INF
group 0 region 0

variable  Natom  equal count(0)
variable  NA  equal ${Natom}
variable j loop ${NA}
variable N equal ${j}
variable ax equal xlo+5
variable aax equal ${ax}
variable bx equal xhi-5
variable bbx equal ${bx}
variable ay equal ylo+5
variable aay equal ${ay}
variable by equal yhi-5
variable bby equal ${by}
variable az equal zlo+5
variable aaz equal ${az}
variable bz equal zhi-5
variable bbz equal ${bz}
variable c equal type[$j]
variable d equal x[$j]
variable e equal y[$j]
variable f equal z[$j]
variable cx equal $d
variable cy equal $e
variable cz equal $f


if  "$c == 4 && $d>=${ax} && $d<=${bx} && $e>=${ay} && $e<=${by} && $f>=${az} && $f<=${bz}" then &
"write_data ${name}_${N}.data" &
"region 1 sphere ${cx} ${cy} ${cz} 1.86 side out" &
"region 2 sphere ${cx} ${cy} ${cz} 1 side in" &
"region 3 union 2 1 2" &
"delete_atoms region 3" &
elif $j==${NA} &
"next name" &
"jump a-d-BOP.in loop3" &
else &
"next j" &
"clear" &
"jump a-d-BOP.in loop2"  

label loop4
variable i loop 3
variable x equal x[$i]
variable y equal y[$i]
variable z equal z[$i]
variable $ix equal $x
variable $iy equal $y
variable $iz equal $z
next i
jump a-d-BOP.in loop4

clear
units        metal
boundary     s s s
atom_style   atomic
atom_modify    map  yes

read_data   ${name}a.data
label loop5
region shelln1i sphere ${1x} ${1y} ${1z} 1.86 side in
region shelln1o sphere ${1x} ${1y} ${1z} 1 side out
region shelln1 intersect 2 shelln1i shelln1o
region shelln2i sphere ${2x} ${2y} ${2z} 1.86 side in
region shelln2o sphere ${2x} ${2y} ${2z} 1 side out
region shelln2 intersect 2 shelln2i shelln2o
region shelln3i sphere ${3x} ${3y} ${3z} 1.86 side in
region shelln3o sphere ${3x} ${3y} ${3z} 1 side out
region shelln3 intersect 2 shelln3i shelln3o
region core sphere ${cx} ${cy} ${cz} 1 side in
delete_atoms region core
region shelln union 3 shelln1 shelln2 shelln3
group shelln region shelln
group boundary subtract all shelln
delete_atoms group boundary
variable  Nshelln  equal count(shelln)

variable k loop ${Nshelln}
variable g equal type[$k]
variable gg equal $g
variable x equal x[$k]
variable y equal y[$k]
variable z equal z[$k]
variable nx equal $x
variable ny equal $y
variable nz equal $z
clear
units     metal
boundary     s s s
atom_style   atomic
atom_modify    map  yes
read_data   ${name}_$j.data
if  "${gg} == 2 " then &
"region $k1 sphere ${nx} ${ny} ${nz} 1.86 side in" &
"set region $k1 type 9" &
"region $k11 sphere ${nx} ${ny} ${nz} 1 side in" &
"set region $k11 type 8" &
"write_data ${name}_$j.data" 
next k
jump a-d-BOP.in loop5

region 4 sphere ${cx} ${cy} ${cz} 1.86 side in 
set region 4 type 10
region 44 sphere ${cx} ${cy} ${cz} 1 side in 
set region 44 type 8
region 5 sphere ${cx} ${cy} ${cz} 6 side out
delete_atoms region 5
write_data ${name}_$j.data

clear
units     metal
boundary     p p p
atom_style   atomic
atom_modify    map  yes
read_data   ${name}_$j.data
group 5 type 1 2 3 4 5 6 7
delete_atoms group 5
set type 10 type 5
set type 9 type 3
set type 8 type 2
region 5 sphere ${cx} ${cy} ${cz} 1 side in 
set region 5 type 4
write_data ${name}_$j.data

label loop6
clear
units     metal
boundary     s s s
atom_style   atomic
atom_modify    map  yes
read_data   ${name}_$j.data
region cluster block INF INF INF INF INF INF
group cluster region cluster
variable  Ncluster  equal count(cluster)
variable NN equal ${Ncluster}
variable l loop ${Ncluster}
variable d equal type[$l]
variable dd equal $d
variable x equal x[$l]
variable y equal y[$l]
variable z equal z[$l]
variable mx equal $x
variable my equal $y
variable mz equal $z

group 6 type 1 3 5 6 7 8 9 10
delete_atoms group 6

pair_style  airebo/morse 3.0 1 1
pair_coeff  * * CH.airebo-m C C C C C C C C C C

if  "${dd} != 4 && ${l} ==${NN} " then &
"jump a-d-BOP.in loop7"

if  "${dd} == 4" then &
"region 1 sphere ${mx} ${my} ${mz} 1 side in" &
"group 1 region 1" &
else &
"next l" &
"clear" &
"jump a-d-BOP.in loop6" 

compute 1 1 orientorder/atom degrees 2 4 6 nnn NULL cutoff 3.6
compute 11 1 reduce sum c_1[1]
compute 12 1 reduce sum c_1[2]

thermo  10
thermo_style custom  step c_11  c_12 

run 0

variable Q4 equal c_11
variable Q6 equal c_12

print "${Q4} "  append  Q4-BOP.text screen yes
print "${Q6} "  append  Q6-BOP.text screen yes

label loop7
next l
clear
jump a-d-BOP.in loop6

if  "${N}==${NA} && ${cx}>=${aax} && ${cx}<=${bbx} && ${cy}>=${aay} && ${cy}<=${bby} && ${cz}>=${aaz} && ${cz}<=${bbz} " then &
"next name"
 
label loop3
next j
jump a-d-BOP.in loop2

clear
jump a-d-BOP.in loop1







